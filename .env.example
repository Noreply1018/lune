# Lune 生产 compose 环境变量示例。复制为 .env 后按需修改。
# docker compose -f docker-compose.prod.yml --env-file .env up -d

# --- 镜像版本 ---
# 默认 latest；锁版本建议填 0.1.0 之类的 tag（不带 v 前缀）
LUNE_IMAGE_TAG=latest

# --- Lune ---
# HTTP 端口（容器内 + 宿主机）
LUNE_PORT=7788

# Admin Token；留空由 Lune 首次启动自动生成（可在 /admin 页面查看）
LUNE_ADMIN_TOKEN=

# --- CPA ---
# Lune 与 CPA 之间通信的 API Key，任意字符串即可，但两边必须一致
CPA_API_KEY=sk-cpa-default

# Lune 访问 CPA 管理 API 的密钥（对应 cpa-config.yaml 里的 remote-management.secret-key）
LUNE_CPA_MANAGEMENT_KEY=lune-cpa-management-dev

# --- 日志（可选）---
# LUNE_LOG_LEVEL=info       # debug | info | warn | error
# LUNE_LOG_FORMAT=text      # text | json
